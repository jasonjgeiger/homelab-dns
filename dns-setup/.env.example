# Copy to .env or deploy with: ./deploy.sh .env.vm1
# Required on each Docker host (Proxmox LXC or VM).

# Host NIC that reaches your LAN (inside the LXC/VM)
PARENT_INTERFACE=eth0

# Must match your LAN; same values on both DNS nodes
MACVLAN_SUBNET=192.168.100.0/24
MACVLAN_GATEWAY=192.168.100.1
MACVLAN_NETWORK_NAME=pihole_macvlan

# Unique per node — Pi-hole container address on macvlan
PIHOLE_IPV4=192.168.100.5

# Virtual IP clients use for DNS (keepalived VIP); same on both nodes
SERVERIP=192.168.100.100

# Upstream: dnscrypt-proxy on Docker bridge 10.0.1.2 (see ../dnscrypt-proxy/compose.yml)
# Use plain IPs for public DNS instead, or add DNS2=1.1.1.1 as fallback
DNS1=10.0.1.2#5300
DNS2=no

TZ=America/Los_Angeles
# Web + API login (Pi-hole v6: mapped in ../pihole/compose.yml).
# With this env set, the password is fixed by Docker and won’t match changes made only in the UI.
WEBPASSWORD=changeme

# keepalived — must differ per node; auth must match on both
ROUTER_ID=PIHOLE_VM1
VRRP_STATE=MASTER
VRRP_PRIORITY=110
VRRP_AUTH_PASS=replace_with_shared_secret
UNICAST_SRC_IP=192.168.100.5
UNICAST_PEER_IP=192.168.100.10
VIP_CIDR=192.168.100.100/24
