# Pi-hole v6 sync — https://github.com/lovelaze/nebula-sync (included from repo root compose.yml)
# Format: http(s)://host|password (password = web UI / API password or app password)
# Use the same PRIMARY/REPLICAS on dns1 and dns2 (each node’s stack reaches the Pi-hole IPs on the LAN).

PRIMARY=http://192.168.100.5|changeme
REPLICAS=http://192.168.100.10|changeme

FULL_SYNC=true
RUN_GRAVITY=true
CRON=*/15 * * * *
TZ=America/Los_Angeles
