# Pi-hole v6 sync via https://github.com/lovelaze/nebula-sync
# Format: http(s)://host|password (password = web UI / API password or app password)
# Run this stack on a host that can reach both Pi-hole instances (not necessarily on the DNS nodes).

PRIMARY=http://192.168.100.5|changeme
REPLICAS=http://192.168.100.10|changeme

FULL_SYNC=true
RUN_GRAVITY=true
CRON=*/15 * * * *
TZ=America/Los_Angeles
