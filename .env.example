# Copy to `.env` in this directory (`cp .env.example .env`).
# Values differ per node where noted.

# Macvlan network pihole_macvlan (same on both DNS nodes for subnet/gateway)
PARENT_INTERFACE=eth0
MACVLAN_SUBNET=192.168.100.0/24
MACVLAN_GATEWAY=192.168.100.1

# Pi-hole container address on macvlan — unique per node
PIHOLE_IPV4=192.168.100.5

# VIP clients use for DNS (keepalived); same on both nodes
SERVERIP=192.168.100.100

# Internal bridge `pihole_net` is 10.0.1.0/24 (dnscrypt 10.0.1.2, Pi-hole 10.0.1.3), same idea as a minimal dns/docker-compose.yml.

# Upstream resolvers for Pi-hole (passed through as DNS1/DNS2 in compose).
# Only one active pair below — pick A or B (or mix ideas: e.g. two public IPs).

# --- A) Through dnscrypt-proxy on the Docker bridge (encrypted upstream; this stack) ---
DNS1=10.0.1.2#5300
DNS2=no

# --- B) Straight to public DNS (Pi-hole talks to the internet directly; dnscrypt unused) ---
# DNS1=1.1.1.1
# DNS2=8.8.8.8

TZ=America/Los_Angeles

# Pi-hole web + API password (same on both nodes if you want one login)
WEBPASSWORD=changeme

# nebula-sync — https://github.com/lovelaze/nebula-sync (same PRIMARY/REPLICAS on both nodes)
PRIMARY=http://192.168.100.5|changeme
REPLICAS=http://192.168.100.10|changeme
FULL_SYNC=true
RUN_GRAVITY=true
CRON="*/15 * * * *"

# keepalived (VRRP) — ./stack.sh render-keepalived writes ./keepalived/assets/keepalived.conf (see ./keepalived/assets/notify.sh for osixia image)
ROUTER_ID=PIHOLE_PRIMARY
VRRP_STATE=MASTER
VRRP_PRIORITY=110
VRRP_AUTH_PASS=replace_with_shared_secret
UNICAST_SRC_IP=192.168.100.5
UNICAST_PEER_IP=192.168.100.10
VIP_CIDR=192.168.100.100/24
