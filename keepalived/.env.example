# Not read by `docker compose` — only used with `envsubst` to build `assets/keepalived.conf` (mounted by Compose).
# Copy to `.env` in this directory, then render:
#   set -a && source .env && set +a && envsubst < keepalived.conf.template > assets/keepalived.conf
# Values differ per node where noted; VRRP_AUTH_PASS must match on both nodes.

ROUTER_ID=PIHOLE_VM1
VRRP_STATE=MASTER
VRRP_PRIORITY=110
VRRP_AUTH_PASS=replace_with_shared_secret
UNICAST_SRC_IP=192.168.100.5
UNICAST_PEER_IP=192.168.100.10
VIP_CIDR=192.168.100.100/24
